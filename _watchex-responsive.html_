<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Watchex — Premium Watches | Starting at Rs.1499</title>
<style>
  :root{
    --ink:#0B0612;
    --panel:#170F22;
    --panel-2:#1F1530;
    --violet:#A855F7;
    --violet-deep:#7C3AED;
    --gold:#FFD700;
    --gold-soft:#F0C24B;
    --cream:#F6F1FB;
    --lav:#B8A8D0;
    --line:rgba(168,85,247,0.22);
    --line-gold:rgba(255,215,0,0.25);
    --radius:18px;
  }

  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--ink);
    color:var(--cream);
    font-family:'Inter',-apple-system,sans-serif;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }

  h1,h2,h3{
    font-family:'Cormorant Garamond','Georgia',serif;
    font-weight:600;
    letter-spacing:0.01em;
  }

  .eyebrow{
    font-family:'Inter',sans-serif;
    text-transform:uppercase;
    letter-spacing:0.25em;
    font-size:0.72rem;
    background:linear-gradient(90deg,var(--violet),var(--gold));
    -webkit-background-clip:text;background-clip:text;color:transparent;
    font-weight:700;
  }

  .container{
    max-width:1180px;
    margin:0 auto;
    padding:0 24px;
  }

  /* AMBIENT BACKGROUND */
  .bg-orb{
    position:fixed;
    border-radius:50%;
    filter:blur(90px);
    z-index:0;
    pointer-events:none;
    opacity:0.45;
  }
  .orb-1{
    width:500px;height:500px;
    background:var(--violet);
    top:-150px;left:-150px;
  }
  .orb-2{
    width:600px;height:600px;
    background:var(--gold);
    top:30%;right:-250px;
    opacity:0.25;
  }
  .orb-3{
    width:450px;height:450px;
    background:var(--violet-deep);
    bottom:-200px;left:20%;
    opacity:0.3;
  }

  /* NAV */
  nav{
    position:sticky;top:0;z-index:50;
    background:rgba(11,6,18,0.75);
    backdrop-filter:blur(14px);
    border-bottom:1px solid var(--line);
  }
  .nav-inner{
    display:flex;align-items:center;justify-content:space-between;
    padding:18px 24px;max-width:1180px;margin:0 auto;
  }
  .brand{
    font-family:'Cormorant Garamond',serif;
    font-size:1.6rem;letter-spacing:0.06em;
    background:linear-gradient(90deg,var(--gold),var(--violet));
    -webkit-background-clip:text;background-clip:text;color:transparent;
    font-weight:700;
  }
  .nav-cta{
    background:linear-gradient(90deg,var(--violet),var(--violet-deep));
    color:var(--cream);
    padding:11px 26px;
    border-radius:999px;
    font-size:0.85rem;
    font-weight:600;
    letter-spacing:0.04em;
    text-decoration:none;
    border:1px solid var(--line-gold);
    transition:all 0.25s ease;
    box-shadow:0 4px 20px -6px rgba(168,85,247,0.5);
    cursor:pointer;
    min-height:44px;
    display:flex;
    align-items:center;
  }
  .nav-cta:hover{transform:translateY(-1px);box-shadow:0 8px 26px -6px rgba(255,215,0,0.4);}

  /* HERO */
  .hero{
    position:relative;
    padding:90px 24px 60px;
    text-align:center;
    overflow:hidden;
    z-index:1;
  }
  .hero-content{position:relative;z-index:2;max-width:780px;margin:0 auto;}
  .hero h1{
    font-size:clamp(2.4rem,6vw,4.4rem);
    line-height:1.12;
    margin:18px 0 20px;
    color:var(--cream);
  }
  .hero h1 .accent{
    background:linear-gradient(90deg,var(--gold),var(--violet) 80%);
    -webkit-background-clip:text;background-clip:text;color:transparent;
    font-style:italic;
  }
  .hero p.sub{
    font-size:1.18rem;
    color:var(--lav);
    max-width:580px;
    margin:0 auto 36px;
  }

  .price-tag{
    display:inline-flex;align-items:center;gap:10px;
    border:1px solid var(--line-gold);
    border-radius:999px;
    padding:10px 26px;
    margin-bottom:34px;
    font-size:0.95rem;
    color:var(--cream);
    background:rgba(255,215,0,0.06);
    flex-wrap:wrap;
    justify-content:center;
  }
  .price-tag strong{
    font-family:'Cormorant Garamond',serif;
    font-size:1.4rem;
    background:linear-gradient(90deg,var(--gold),var(--violet));
    -webkit-background-clip:text;background-clip:text;color:transparent;
  }

  .btn-primary{
    display:inline-block;
    background:linear-gradient(90deg,var(--gold) 0%,var(--violet) 100%);
    color:var(--ink);
    font-weight:800;
    padding:19px 50px;
    border-radius:999px;
    text-decoration:none;
    font-size:1.08rem;
    letter-spacing:0.02em;
    transition:transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
    box-shadow:0 10px 40px -10px rgba(168,85,247,0.6);
    cursor:pointer;
    border:none;
    min-height:44px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
  }
  .btn-primary:hover{transform:translateY(-3px) scale(1.02);filter:brightness(1.08);box-shadow:0 16px 50px -10px rgba(255,215,0,0.5);}
  .btn-note{
    display:block;margin-top:14px;font-size:0.82rem;color:var(--lav);
    letter-spacing:0.04em;
  }

  /* COLLECTION */
  .collection{position:relative;z-index:1;}
  .section-head{text-align:center;max-width:680px;margin:0 auto 56px;}
  .section-head h2{font-size:clamp(1.9rem,4vw,2.9rem);margin:14px 0 16px;color:var(--cream);}
  .section-head p{color:var(--lav);font-size:1.05rem;}
  .divider{
    width:70px;height:2px;
    background:linear-gradient(90deg,var(--gold),var(--violet));
    margin:0 auto;border-radius:2px;
  }

  section{padding:90px 0;position:relative;z-index:1;}

  .collection-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:32px;
    perspective:1000px;
  }

  .product-card{
    position:relative;
    background:linear-gradient(160deg,var(--panel-2),var(--panel));
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:26px;
    text-align:center;
    transition:transform 0.12s ease-out, box-shadow 0.3s ease, border-color 0.3s ease;
    transform-style:preserve-3d;
    will-change:transform;
    cursor:pointer;
  }
  .product-card:hover{
    border-color:var(--line-gold);
    box-shadow:0 25px 60px -20px rgba(168,85,247,0.5);
  }
  .product-card .glow{
    position:absolute;inset:0;
    border-radius:var(--radius);
    background:radial-gradient(circle at var(--mx,50%) var(--my,50%), rgba(255,215,0,0.18), transparent 60%);
    opacity:0;
    transition:opacity 0.3s ease;
    pointer-events:none;
  }
  .product-card:hover .glow{opacity:1;}

  .product-photo{
    width:100%;
    aspect-ratio:1/1;
    border-radius:14px;
    overflow:hidden;
    margin-bottom:18px;
    background:linear-gradient(135deg,#2a1a3e,#1a0f2e);
    display:flex;align-items:center;justify-content:center;
    border:1px solid var(--line);
    transform:translateZ(20px);
    color:#999;
    font-size:1rem;
  }

  .product-card h3{
    font-size:1.35rem;color:var(--cream);margin-bottom:8px;
    transform:translateZ(15px);
  }
  .product-card .tag{
    display:inline-block;
    font-size:0.7rem;letter-spacing:0.12em;text-transform:uppercase;
    color:var(--gold-soft);
    border:1px solid var(--line-gold);
    border-radius:999px;
    padding:4px 14px;margin-bottom:12px;
    transform:translateZ(15px);
  }
  .product-card .price-row{
    display:flex;align-items:center;justify-content:center;gap:10px;
    margin:12px 0 18px;
    transform:translateZ(15px);
    flex-wrap:wrap;
  }
  .product-card .price-now{
    font-family:'Cormorant Garamond',serif;font-size:1.5rem;
    color:var(--gold);font-weight:700;
  }
  .product-card .price-old{
    font-size:0.9rem;color:var(--lav);text-decoration:line-through;opacity:0.6;
  }
  .product-card .card-btn{
    display:inline-block;width:100%;
    background:linear-gradient(90deg,var(--violet),var(--violet-deep));
    color:var(--cream);font-weight:700;
    padding:12px 0;border-radius:999px;
    text-decoration:none;font-size:0.9rem;
    border:1px solid var(--line-gold);
    transition:filter 0.2s ease;
    transform:translateZ(15px);
    cursor:pointer;
    min-height:44px;
    display:flex;
    align-items:center;
    justify-content:center;
  }
  .product-card .card-btn:hover{filter:brightness(1.15);}

  /* BENEFITS */
  .benefits{background:var(--panel);border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
  .benefit-grid{
    display:grid;grid-template-columns:repeat(3,1fr);gap:30px;
  }
  .benefit-card{
    background:linear-gradient(160deg,var(--panel-2),var(--panel));
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:38px 28px;
    text-align:center;
    transition:border-color 0.25s ease, transform 0.25s ease;
  }
  .benefit-card:hover{border-color:var(--line-gold);transform:translateY(-6px);}
  .benefit-icon{
    width:60px;height:60px;border-radius:50%;
    background:linear-gradient(135deg,var(--violet),var(--violet-deep));
    display:flex;align-items:center;justify-content:center;
    margin:0 auto 22px;color:var(--gold);font-size:1.6rem;
    box-shadow:0 8px 24px -6px rgba(168,85,247,0.6);
  }
  .benefit-card h3{font-size:1.35rem;color:var(--cream);margin-bottom:12px;}
  .benefit-card p{color:var(--lav);font-size:0.96rem;}

  /* FOOTER */
  footer{
    text-align:center;padding:40px 24px;color:var(--lav);
    font-size:0.85rem;border-top:1px solid var(--line);
    letter-spacing:0.04em;position:relative;z-index:1;
  }
  footer .brand-foot{
    font-family:'Cormorant Garamond',serif;font-size:1.2rem;display:block;margin-bottom:8px;
    background:linear-gradient(90deg,var(--gold),var(--violet));
    -webkit-background-clip:text;background-clip:text;color:transparent;
  }

  /* MODAL */
  .modal-overlay{
    position:fixed;inset:0;
    background:rgba(8,4,14,0.8);
    backdrop-filter:blur(6px);
    display:none;
    align-items:center;justify-content:center;
    z-index:100;
    padding:20px;
    overflow-y:auto;
  }
  .modal-overlay.active{display:flex;}
  .modal-box{
    background:linear-gradient(160deg,var(--panel-2),var(--panel));
    border:1px solid var(--line-gold);
    border-radius:var(--radius);
    max-width:440px;width:100%;
    padding:38px 32px;
    position:relative;
    box-shadow:0 30px 90px -20px rgba(168,85,247,0.5);
    animation:modalIn 0.25s ease;
    margin:auto;
  }
  @keyframes modalIn{
    from{opacity:0;transform:translateY(14px) scale(0.98);}
    to{opacity:1;transform:translateY(0) scale(1);}
  }
  .modal-close{
    position:absolute;top:18px;right:20px;
    background:none;border:none;color:var(--lav);
    font-size:1.4rem;cursor:pointer;line-height:1;
    transition:color 0.2s ease;
    min-width:44px;min-height:44px;
    display:flex;align-items:center;justify-content:center;
  }
  .modal-close:hover{color:var(--gold);}
  .modal-box h3{font-size:1.6rem;color:var(--cream);margin-bottom:6px;}
  .modal-box .modal-sub{color:var(--lav);font-size:0.92rem;margin-bottom:24px;}
  .form-group{margin-bottom:18px;}
  .form-group label{
    display:block;font-size:0.78rem;letter-spacing:0.08em;
    text-transform:uppercase;color:var(--gold-soft);margin-bottom:8px;
  }
  .form-group input,.form-group select{
    width:100%;
    background:var(--ink);
    border:1px solid var(--line);
    border-radius:8px;
    padding:13px 14px;
    color:var(--cream);
    font-family:'Inter',sans-serif;
    font-size:0.95rem;
    outline:none;
    transition:border-color 0.2s ease;
  }
  .form-group input:focus,.form-group select:focus{border-color:var(--violet);}
  .form-submit{
    width:100%;
    background:linear-gradient(90deg,var(--gold),var(--violet));
    color:var(--ink);
    border:none;
    font-weight:800;
    padding:15px;
    border-radius:999px;
    font-size:1rem;
    cursor:pointer;
    transition:transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow:0 8px 30px -8px rgba(168,85,247,0.5);
    min-height:44px;
  }
  .form-submit:hover{transform:translateY(-2px);}
  .form-note{
    text-align:center;font-size:0.8rem;color:var(--lav);
    margin-top:14px;
  }
  .form-status{
    text-align:center;font-size:0.9rem;margin-top:14px;
    display:none;
  }
  .form-status.success{display:block;color:var(--gold-soft);}
  .form-status.error{display:block;color:#ef9b9b;}

  /* ===== RESPONSIVE BREAKPOINTS ===== */

  /* TABLETS - 1024px and below */
  @media (max-width:1024px){
    .collection-grid{grid-template-columns:repeat(2,1fr);gap:24px;}
    .benefit-grid{grid-template-columns:repeat(2,1fr);gap:24px;}
    .hero{padding:70px 24px 50px;}
    section{padding:70px 0;}
    .modal-box{padding:32px 28px;}
  }

  /* LANDSCAPE TABLETS - 900px and below */
  @media (max-width:900px){
    .benefit-grid{grid-template-columns:1fr;}
    section{padding:64px 0;}
    .nav-inner{padding:14px 20px;}
    .brand{font-size:1.3rem;}
  }

  /* MOBILE LANDSCAPE - 820px and below */
  @media (max-width:820px){
    .orb-1{width:350px;height:350px;top:-100px;left:-100px;}
    .orb-2{width:400px;height:400px;top:40%;right:-200px;}
    .orb-3{width:300px;height:300px;bottom:-150px;left:10%;}
  }

  /* MOBILE PORTRAIT - 640px and below */
  @media (max-width:640px){
    :root{--radius:14px;}
    
    .container{padding:0 16px;}
    
    /* NAV */
    .nav-inner{padding:12px 16px;}
    .brand{font-size:1.1rem;}
    .nav-cta{padding:9px 18px;font-size:0.75rem;}
    
    /* HERO */
    .hero{padding:60px 16px 45px;}
    .hero h1{font-size:clamp(1.8rem,5vw,2.8rem);margin:12px 0 16px;}
    .hero p.sub{font-size:0.95rem;margin:0 auto 24px;}
    
    .price-tag{padding:8px 16px;margin-bottom:24px;font-size:0.8rem;}
    .price-tag strong{font-size:1.1rem;}
    
    .btn-primary{padding:16px 40px;font-size:0.95rem;}
    .btn-note{font-size:0.75rem;margin-top:10px;}
    
    /* SECTIONS */
    section{padding:50px 0;}
    .section-head{margin:0 auto 40px;}
    .section-head h2{font-size:clamp(1.4rem,3vw,2rem);margin:10px 0 12px;}
    .section-head p{font-size:0.9rem;}
    
    /* COLLECTION GRID */
    .collection-grid{grid-template-columns:1fr;gap:20px;}
    
    .product-card{padding:20px;}
    .product-card h3{font-size:1.1rem;margin-bottom:6px;}
    .product-card .tag{font-size:0.65rem;padding:3px 10px;}
    .product-card .price-row{margin:10px 0 14px;}
    .product-card .price-now{font-size:1.2rem;}
    .product-card .price-old{font-size:0.8rem;}
    .product-card .card-btn{font-size:0.8rem;}
    
    /* BENEFITS */
    .benefit-grid{grid-template-columns:1fr;gap:20px;}
    .benefit-card{padding:28px 20px;}
    .benefit-icon{width:50px;height:50px;margin:0 auto 16px;font-size:1.2rem;}
    .benefit-card h3{font-size:1.1rem;margin-bottom:8px;}
    .benefit-card p{font-size:0.85rem;}
    
    /* MODAL */
    .modal-overlay{padding:16px;}
    .modal-box{
      max-width:100%;
      padding:24px 20px;
      border-radius:14px;
    }
    .modal-close{top:12px;right:12px;font-size:1.2rem;}
    .modal-box h3{font-size:1.3rem;margin-bottom:4px;}
    .modal-box .modal-sub{font-size:0.85rem;margin-bottom:16px;}
    
    .form-group{margin-bottom:14px;}
    .form-group label{font-size:0.7rem;margin-bottom:6px;}
    .form-group input,.form-group select{
      padding:12px 12px;
      font-size:16px;
      border-radius:6px;
    }
    .form-submit{padding:14px;font-size:0.95rem;}
    .form-note{font-size:0.75rem;margin-top:10px;}
    
    /* FOOTER */
    footer{padding:30px 16px;}
    footer .brand-foot{font-size:1rem;margin-bottom:6px;}
    footer p{font-size:0.75rem;}
  }

  /* SMALL MOBILE - 480px and below */
  @media (max-width:480px){
    .container{padding:0 12px;}
    
    .nav-inner{padding:10px 12px;}
    .brand{font-size:0.95rem;}
    .nav-cta{padding:8px 14px;font-size:0.7rem;}
    
    .hero{padding:45px 12px 35px;}
    .hero h1{font-size:clamp(1.5rem,4vw,2.2rem);margin:10px 0 12px;}
    .hero p.sub{font-size:0.85rem;margin:0 auto 18px;}
    
    .price-tag{padding:6px 12px;margin-bottom:18px;font-size:0.7rem;}
    .price-tag strong{font-size:0.95rem;}
    
    .btn-primary{padding:14px 30px;font-size:0.85rem;}
    
    section{padding:40px 0;}
    .section-head{margin:0 auto 32px;}
    .section-head h2{font-size:clamp(1.2rem,2.5vw,1.6rem);}
    
    .product-card{padding:16px;}
    .product-card h3{font-size:0.95rem;}
    
    .benefit-card{padding:20px 16px;}
    .benefit-icon{width:45px;height:45px;font-size:1rem;}
    .benefit-card h3{font-size:0.95rem;}
    .benefit-card p{font-size:0.8rem;}
    
    .modal-box{padding:20px 16px;}
    .modal-box h3{font-size:1.1rem;}
    .form-group input,.form-group select{font-size:16px;}
  }

  /* VERY SMALL - 360px and below */
  @media (max-width:360px){
    .nav-inner{padding:8px 10px;}
    .hero h1{font-size:clamp(1.3rem,3.5vw,1.8rem);}
    .btn-primary{padding:12px 24px;font-size:0.8rem;}
    .product-card{padding:14px;}
    .modal-box{padding:18px 14px;}
  }
</style>
</head>
<body>

<div class="bg-orb orb-1"></div>
<div class="bg-orb orb-2"></div>
<div class="bg-orb orb-3"></div>

<nav>
  <div class="nav-inner">
    <div class="brand">Watchex</div>
    <button class="nav-cta" onclick="openOrderForm()">Order Now</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="eyebrow">Premium Quality · Rs.1499 Starting Price</div>
    <h1>Watches That Redefine <span class="accent">Luxury & Style</span></h1>
    <p class="sub">Discover our exclusive collection of premium timepieces designed for those who value quality, precision, and timeless elegance.</p>

    <div class="price-tag">
      Starting at <strong>Rs.1499</strong> · Nationwide Delivery
    </div>
    <br>
    <button class="btn-primary" onclick="document.getElementById('collection').scrollIntoView();">Explore Collection</button>
    <span class="btn-note">Free shipping on orders above Rs.2999 · Lifetime warranty on select models</span>
  </div>
</section>

<!-- COLLECTION -->
<section class="collection" id="collection">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">Our Collection</div>
      <h2>Six Timeless Designs</h2>
      <p>Each watch is a masterpiece, crafted to perfection with attention to every detail.</p>
      <div class="divider"></div>
    </div>

    <div class="collection-grid">
      <div class="product-card">
        <div class="glow"></div>
        <div class="product-photo">Watch Image 1</div>
        <h3>Elegant Classic</h3>
        <span class="tag">Best Seller</span>
        <div class="price-row">
          <span class="price-now">Rs.1,499</span>
          <span class="price-old">Rs.2,999</span>
        </div>
        <button class="card-btn" onclick="openOrderForm('Elegant Classic')">Add to Cart</button>
      </div>

      <div class="product-card">
        <div class="glow"></div>
        <div class="product-photo">Watch Image 2</div>
        <h3>Modern Minimalist</h3>
        <span class="tag">Premium</span>
        <div class="price-row">
          <span class="price-now">Rs.1,899</span>
          <span class="price-old">Rs.3,499</span>
        </div>
        <button class="card-btn" onclick="openOrderForm('Modern Minimalist')">Add to Cart</button>
      </div>

      <div class="product-card">
        <div class="glow"></div>
        <div class="product-photo">Watch Image 3</div>
        <h3>Luxury Skeleton</h3>
        <span class="tag">Limited</span>
        <div class="price-row">
          <span class="price-now">Rs.2,299</span>
          <span class="price-old">Rs.4,499</span>
        </div>
        <button class="card-btn" onclick="openOrderForm('Luxury Skeleton')">Add to Cart</button>
      </div>

      <div class="product-card">
        <div class="glow"></div>
        <div class="product-photo">Watch Image 4</div>
        <h3>Sports Dynamic</h3>
        <span class="tag">New</span>
        <div class="price-row">
          <span class="price-now">Rs.1,699</span>
          <span class="price-old">Rs.3,199</span>
        </div>
        <button class="card-btn" onclick="openOrderForm('Sports Dynamic')">Add to Cart</button>
      </div>

      <div class="product-card">
        <div class="glow"></div>
        <div class="product-photo">Watch Image 5</div>
        <h3>Heritage Gold</h3>
        <span class="tag">Bestseller</span>
        <div class="price-row">
          <span class="price-now">Rs.1,999</span>
          <span class="price-old">Rs.3,799</span>
        </div>
        <button class="card-btn" onclick="openOrderForm('Heritage Gold')">Add to Cart</button>
      </div>

      <div class="product-card">
        <div class="glow"></div>
        <div class="product-photo">Watch Image 6</div>
        <h3>Urban Edge</h3>
        <span class="tag">Trending</span>
        <div class="price-row">
          <span class="price-now">Rs.1,599</span>
          <span class="price-old">Rs.2,999</span>
        </div>
        <button class="card-btn" onclick="openOrderForm('Urban Edge')">Add to Cart</button>
      </div>
    </div>
  </div>
</section>

<!-- BENEFITS -->
<section class="benefits">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">Why Choose Watchex</div>
      <h2>Premium Quality at Affordable Prices</h2>
      <p>Experience luxury without compromise</p>
      <div class="divider"></div>
    </div>

    <div class="benefit-grid">
      <div class="benefit-card">
        <div class="benefit-icon">⏱</div>
        <h3>Swiss Movement</h3>
        <p>Precision-engineered movements for accurate timekeeping and durability.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">✨</div>
        <h3>Premium Materials</h3>
        <p>Crafted with stainless steel, sapphire crystal, and genuine leather straps.</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">🛡</div>
        <h3>Lifetime Warranty</h3>
        <p>Complete warranty and after-sales support on all premium models.</p>
      </div>
    </div>
  </div>
</section>

<!-- ORDER MODAL -->
<div class="modal-overlay" id="orderModal">
  <div class="modal-box">
    <button class="modal-close" onclick="closeOrderForm()" aria-label="Close order form">✕</button>
    <h3>Place Your Order</h3>
    <p class="modal-sub">Selected: <span id="selectedProduct">Watchex Watch</span></p>
    
    <form onsubmit="handleSubmit(event)">
      <div class="form-group">
        <label for="fullName">Full Name</label>
        <input type="text" id="fullName" placeholder="John Doe" required>
      </div>

      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" placeholder="john@example.com" required>
      </div>

      <div class="form-group">
        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" placeholder="+92 300 1234567" required>
      </div>

      <div class="form-group">
        <label for="address">Shipping Address</label>
        <input type="text" id="address" placeholder="Enter your address" required>
      </div>

      <div class="form-group">
        <label for="payment">Payment Method</label>
        <select id="payment" required>
          <option value="">Select a payment method</option>
          <option value="cod">Cash on Delivery</option>
          <option value="bank">Bank Transfer</option>
          <option value="card">Credit/Debit Card</option>
        </select>
      </div>

      <button type="submit" class="form-submit">Complete Order</button>
      <p class="form-note">Your order will be processed within 24 hours</p>
      <div class="form-status" id="formStatus"></div>
    </form>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <span class="brand-foot">Watchex</span>
  <p>&copy; 2024 Watchex. All rights reserved. | Premium Watches at Affordable Prices</p>
  <p>Nationwide Delivery | Lifetime Warranty | 24/7 Customer Support</p>
</footer>

<script>
  function openOrderForm(productName = 'Watchex Watch') {
    document.getElementById('selectedProduct').textContent = productName;
    document.getElementById('orderModal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeOrderForm() {
    document.getElementById('orderModal').classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function handleSubmit(event) {
    event.preventDefault();
    const status = document.getElementById('formStatus');
    status.textContent = '✓ Order placed successfully! We will contact you soon.';
    status.classList.add('success');
    setTimeout(() => {
      closeOrderForm();
      event.target.reset();
      status.classList.remove('success');
    }, 2000);
  }

  window.onclick = function(event) {
    const modal = document.getElementById('orderModal');
    if (event.target === modal) {
      closeOrderForm();
    }
  }

  // Close modal with Escape key
  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
      closeOrderForm();
    }
  });
</script>

</body>
</html>